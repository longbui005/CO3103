# Django runtime
DEBUG=False
SECRET_KEY=replace-with-strong-random-secret
ALLOWED_HOSTS=your-domain.com,www.your-domain.com
TIME_ZONE=UTC

# Database (RDS recommended)
DATABASE_URL=postgresql://db_user:db_password@db-host.region.rds.amazonaws.com:5432/jobfinder

# CORS/CSRF
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Optional secure cookie overrides
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# Optional Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Optional superuser bootstrap
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=replace-with-strong-password
